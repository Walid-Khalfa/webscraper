DATABASE_URL=postgresql://user:password@host:5432/database
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security secrets
CRON_SECRET=replace-with-a-long-random-secret
ADMIN_SECRET=replace-with-a-long-random-secret
EMAIL_LINK_SECRET=replace-with-a-long-random-secret

# Email provider
RESEND_API_KEY=replace-me
EMAIL_FROM=KhalfaJobs <alerts@example.com>

# Bundesagentur API (optional OAuth)
BA_CLIENT_ID=
BA_CLIENT_SECRET=
BA_TOKEN_URL=
BA_TIMEOUT_MS=12000

# Runtime tuning
CRON_AGENT_CONCURRENCY=4
PRISMA_MAX_CONCURRENT=6
SKIP_DB_DURING_BUILD=false

# Distributed rate limiting (recommended for production SaaS)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
