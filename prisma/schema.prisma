datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AgencyRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
}

enum ImportedJobStatus {
  ACTIVE
  EXPIRED
  REMOVED
  UNKNOWN
}

enum ImportRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model Agency {
  id                      Int                  @id @default(autoincrement())
  name                    String
  email                   String               @unique
  plan                    String               @default("starter")
  apiKeyHash              String               @unique @map("api_key_hash")
  isActive                Boolean              @default(true) @map("is_active")
  emailVerifiedAt         DateTime?            @map("email_verified_at")
  verificationEmailSentAt DateTime?            @map("verification_email_sent_at")
  createdAt               DateTime             @default(now()) @map("created_at")
  subscriptions           SearchSubscription[]
  members                 AgencyUser[]
  auditLogs               AuditLog[]
  searchHistory           SearchHistory[]
  candidateDossiers       CandidateDossier[]
  crmIntegrations         CrmIntegration[]
  billingAccount          BillingAccount?
  complianceProfile       AgencyComplianceProfile?

  @@map("agencies")
}

model AgencyUser {
  id         Int        @id @default(autoincrement())
  agencyId    Int       @map("agency_id")
  email      String
  fullName   String     @map("full_name")
  role       AgencyRole @default(RECRUITER)
  isActive   Boolean    @default(true) @map("is_active")
  invitedAt  DateTime?  @map("invited_at")
  acceptedAt DateTime?  @map("accepted_at")
  lastSeenAt DateTime?  @map("last_seen_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  agency     Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, email])
  @@index([agencyId, role])
  @@map("agency_users")
}

model ProductEvent {
  id         Int      @id @default(autoincrement())
  event      String
  distinctId String?  @map("distinct_id")
  path       String?
  url        String?
  properties Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@map("product_events")
}

model SearchSubscription {
  id                   Int             @id @default(autoincrement())
  agencyId             Int             @map("agency_id")
  keyword              String
  location             String
  frequency            String          @default("daily")
  maxResults           Int             @default(25) @map("max_results")
  isActive             Boolean         @default(true) @map("is_active")
  doubleOptInStatus    String          @default("confirmed") @map("double_opt_in_status")
  doubleOptInTokenHash String?         @map("double_opt_in_token_hash")
  confirmedAt          DateTime?       @map("confirmed_at")
  lastSentAt           DateTime?       @map("last_sent_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  agency               Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  deliveries           EmailDelivery[]

  @@map("search_subscriptions")
}

model EmailDelivery {
  id             Int                @id @default(autoincrement())
  subscriptionId Int                @map("subscription_id")
  recipientEmail String             @map("recipient_email")
  subject        String
  status         String             @default("pending")
  errorMessage   String?            @map("error_message")
  sentAt         DateTime?          @map("sent_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  subscription   SearchSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("email_deliveries")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  agencyId    Int?    @map("agency_id")
  actorEmail String?  @map("actor_email")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  agency     Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
  @@map("audit_logs")
}

model SearchHistory {
  id            Int      @id @default(autoincrement())
  agencyId       Int     @map("agency_id")
  keyword       String
  location      String
  exactLocation Boolean  @default(true) @map("exact_location")
  resultCount   Int      @default(0) @map("result_count")
  exportedCount Int      @default(0) @map("exported_count")
  createdAt     DateTime @default(now()) @map("created_at")
  agency        Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
  @@map("search_history")
}

model CandidateDossier {
  id          Int      @id @default(autoincrement())
  agencyId     Int     @map("agency_id")
  reference   String
  title       String
  employer    String
  location    String
  status      String   @default("interested")
  notes       String   @default("")
  tags        Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, reference])
  @@index([agencyId, status])
  @@map("candidate_dossiers")
}

model CrmIntegration {
  id                Int               @id @default(autoincrement())
  agencyId           Int              @map("agency_id")
  provider          String
  displayName       String            @map("display_name")
  status            IntegrationStatus @default(NOT_CONNECTED)
  externalAccountId String?           @map("external_account_id")
  lastSyncAt        DateTime?         @map("last_sync_at")
  config            Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  agency            Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, provider])
  @@map("crm_integrations")
}

model BillingAccount {
  id               Int           @id @default(autoincrement())
  agencyId          Int          @unique @map("agency_id")
  status           BillingStatus @default(TRIAL)
  planName         String        @default("Starter") @map("plan_name")
  seats            Int           @default(1)
  customerRef      String?       @map("customer_ref")
  trialEndsAt      DateTime?     @map("trial_ends_at")
  currentPeriodEnd DateTime?     @map("current_period_end")
  createdAt        DateTime      @default(now()) @map("created_at")
  agency           Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("billing_accounts")
}

model AgencyComplianceProfile {
  id                    Int      @id @default(autoincrement())
  agencyId               Int     @unique @map("agency_id")
  privacyAcceptedAt     DateTime? @map("privacy_accepted_at")
  termsAcceptedAt       DateTime? @map("terms_accepted_at")
  doubleOptInEnabled    Boolean  @default(true) @map("double_opt_in_enabled")
  auditTrailEnabled     Boolean  @default(true) @map("audit_trail_enabled")
  retentionPolicyDays   Int      @default(180) @map("retention_policy_days")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  agency                Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_compliance_profiles")
}

model ImportedJob {
  id                 Int               @id @default(autoincrement())
  source             String            @default("bundesagentur")
  sourceKey          String            @unique @map("source_key")
  externalId         String?           @map("external_id")
  reference          String?
  title              String
  employer           String?
  location           String?
  postalCode         String?           @map("postal_code")
  city               String?
  country            String            @default("DE")
  contractType       String?           @map("contract_type")
  workTime           String?           @map("work_time")
  salary             String?
  publishedAt        DateTime?         @map("published_at")
  expiresAt          DateTime?         @map("expires_at")
  description        String?
  sourceUrl          String?           @map("source_url")
  sourceName         String            @default("Bundesagentur für Arbeit") @map("source_name")
  remoteMode         String?           @map("remote_mode")
  category           String?
  experienceLevel    String?           @map("experience_level")
  status             ImportedJobStatus @default(UNKNOWN)
  contentHash        String            @map("content_hash")
  rawPayload         Json?             @map("raw_payload")
  firstImportedAt    DateTime          @default(now()) @map("first_imported_at")
  lastImportedAt     DateTime          @default(now()) @map("last_imported_at")
  lastUpdatedAtSource DateTime?        @map("last_updated_at_source")
  lastSeenAt         DateTime          @default(now()) @map("last_seen_at")
  removedAt          DateTime?         @map("removed_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([source, status])
  @@index([lastSeenAt])
  @@index([reference])
  @@index([city])
  @@map("imported_jobs")
}

model ImportRun {
  id                Int             @id @default(autoincrement())
  source            String          @default("bundesagentur")
  mode              String          @default("full")
  status            ImportRunStatus @default(RUNNING)
  sourceUsed        String?         @map("source_used")
  queriesExecuted   Json?           @map("queries_executed")
  totalFound        Int             @default(0) @map("total_found")
  totalFetched      Int             @default(0) @map("total_fetched")
  newCount          Int             @default(0) @map("new_count")
  updatedCount      Int             @default(0) @map("updated_count")
  unchangedCount    Int             @default(0) @map("unchanged_count")
  duplicateCount    Int             @default(0) @map("duplicate_count")
  errorCount        Int             @default(0) @map("error_count")
  expiredCount      Int             @default(0) @map("expired_count")
  removedCount      Int             @default(0) @map("removed_count")
  lastPageFetched   Int             @default(0) @map("last_page_fetched")
  durationMs        Int?            @map("duration_ms")
  recentErrors      Json?           @map("recent_errors")
  notes             Json?
  startedAt         DateTime        @default(now()) @map("started_at")
  completedAt       DateTime?       @map("completed_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([source, startedAt])
  @@index([status, startedAt])
  @@map("import_runs")
}
